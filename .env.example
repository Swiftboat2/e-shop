# Variables de entorno de producción (Vercel).
#
# En desarrollo NO hace falta ninguna: todo corre contra los emuladores de
# Firebase por defecto, sin credenciales (ver README → Desarrollo). Este
# archivo es la referencia para cargar en Vercel al momento del deploy real,
# no para copiarlo a un .env local.

# --- Dominio -----------------------------------------------------------

# Dominio raíz sin protocolo ni subdominio, ej. "midominio.com". Define
# tanto el ruteo por subdominio (proxy.ts) como los links que arma la
# landing (demo, WhatsApp). Requiere el dominio + "*.dominio" agregados
# en Vercel con los nameservers delegados (ver README → Deploy).
NEXT_PUBLIC_ROOT_DOMAIN=midominio.com

# Número de WhatsApp de la plataforma (no el de un comercio), formato
# internacional, solo dígitos, sin "+". Alimenta el botón "Hablar por
# WhatsApp" de la landing. Sin esto cae a un número placeholder que no
# es de nadie.
NEXT_PUBLIC_WHATSAPP_CONTACTO=5491100000000

# --- Firebase (proyecto real, no el emulador demo-eshop) ---------------

# Los cinco NEXT_PUBLIC_FIREBASE_* salen de la config web del proyecto
# (Firebase Console → Configuración del proyecto → tus apps → SDK setup).
# Van expuestos al navegador (client SDK): no son secretos, los limita
# Firestore/Storage Security Rules, no el ocultamiento del valor.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_APP_ID=

# JSON del service account (Admin SDK) en una sola línea, ej.:
#   FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...",...}'
# Se genera en Firebase Console → Configuración del proyecto → Cuentas de
# servicio → Generar nueva clave privada. Este SÍ es secreto: da acceso de
# administrador a Firestore/Auth/Storage sin pasar por las Security Rules.
# Nunca commitear el JSON ni pegarlo fuera del panel de env vars de Vercel.
FIREBASE_SERVICE_ACCOUNT=
